# ============================================================
# GrabGo Web — Environment Variables
# ============================================================
# Copy this file to the relevant app directory as .env.local
# and fill in your values. Never commit .env.local to git.
#
# App-specific files:
#   apps/admin/.env.local
#   apps/landing/.env.local  (if needed)
# ============================================================

# ---- Admin App (apps/admin/.env.local) --------------------

# Backend API base URL (include /api at the end)
# Development:  http://localhost:5000/api
# Production:   https://grabgo-backend.onrender.com/api
NEXT_PUBLIC_API_URL=http://localhost:5000/api
